# screenerd configuration — copy to .env and fill in. NO secrets in this file.
# 12-factor: every setting is an env var (internal/config). Commented lines show
# the built-in default; uncomment to override.

# --- Required ---
ICLOUD_USER=you@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # app-specific password, NOT your Apple ID password
API_TOKEN=change-me                       # Bearer token for the REST API + web UI

# --- Server / networking ---
# IMAP_SERVER=imap.mail.me.com:993
# API_ADDR=127.0.0.1:8443                  # bind addr:port. Use 0.0.0.0:8443 to reach
                                           # the web UI from other LAN machines (e.g. NAS).
# STATE_DIR=/state                         # SQLite + watermarks live here
# LOG_FORMAT=json                          # json | text

# --- Timing (durations accept a 7d day suffix; 0 disables retentions) ---
# IDLE_TIMEOUT=25m
# SWEEP_INTERVAL=10m
# JUNK_RETENTION=7d                        # older Junk -> Deleted Messages (0 = off)
# RECEIPT_RETENTION=30d                    # older Receipts -> Archive (0 = off)
# NEWSLETTER_RETENTION=30d                 # older Newsletters -> Archive (0 = off)
# SCREENED_ID_TTL=72h

# --- Classification ---
# RECEIPT_SUBJECT_MATCH=false              # optional receipt subject heuristic (off = deterministic)

# --- Folder layout (defaults = iCloud) ---
# SCREENED_FOLDER=Screened
# FOLDER_JUNK=Junk
# FOLDER_RECEIPTS=Receipts
# FOLDER_NEWSLETTERS=Newsletters
# FOLDER_ARCHIVE=Archive
# FOLDER_DELETED=Deleted Messages
# FOLDER_SNOOZED=Snoozed

# Snooze subfolders to pre-create under FOLDER_SNOOZED (comma-separated, label
# grammar: 1d10, sat10, 1w, ...). Manually created snooze subfolders are still
# picked up automatically, so this is optional convenience only.
# SNOOZE_LABELS=1d10,1w,sat10
